---
import Nav from '../../../components/jmd/Nav';
import EntrySection from '../../../components/jmd/EntrySection';
import ImageLightbox from '../../../components/jmd/ImageLightbox';

const title = 'Judgement Day 9（ジャッジメント・デイ9） ー ヴァンパイアセイヴァー3on3';
const description = 'Judgement Day 9（ジャッジメント・デイ9） ― 2026年9月20日（日）eスポフィールドにて開催！ヴァンパイアセイヴァー大規模3on3大会。';
const canonicalUrl = 'https://darkstalkers-federation.org/jmd/09/';
const ogImage = 'https://darkstalkers-federation.org/jmd/09/img/ogp.png';

// 対戦表画像（08のものを暫定使用。09用画像ができたら差し替え）
const finalImages   = [{ src: '/jmd/08/img/result/Final.JPG' }];
const secondImages  = [{ src: '/jmd/08/img/result/2_1.JPG' }, { src: '/jmd/08/img/result/2_2.JPG' }];
const playoffImages = [{ src: '/jmd/08/img/result/PlayOff_A.JPG' }, { src: '/jmd/08/img/result/PlayOff_B.JPG' }];
const firstImages   = ['A','B','C','D','E','F','G','H','I','J','K','L','M','N'].map(l => ({ src: `/jmd/08/img/result/${l}.JPG` }));
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <title>{title}</title>
    <meta name="viewport" content="width=device-width,initial-scale=1.0,minimum-scale=1.0,maximum-scale=1.0,user-scalable=no">
    <meta name="description" content={description}>
    <meta name="keywords" content="Judgement Day,ジャッジメント・デイ,JMD,JMD9,ヴァンパイア,ヴァンパイアセイヴァー,格闘ゲーム大会,格ゲー,3on3,東京,eスポフィールド,2026">
    <link rel="canonical" href={canonicalUrl}>

    <meta property="og:title" content={title}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:description" content={description}>
    <meta property="og:locale" content="ja_JP">
    <meta property="og:site_name" content="Darkstalkers Federation">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@ds_federation">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Event",
      "name": "Judgement Day 9（ジャッジメント・デイ9）",
      "description": "ヴァンパイアセイヴァー大規模3on3大会",
      "startDate": "2026-09-20",
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": "eスポフィールド",
        "url": "https://espofield.com/",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "JP",
          "addressLocality": "東京"
        }
      },
      "organizer": {
        "@type": "Organization",
        "name": "Darkstalkers Federation",
        "url": "https://darkstalkers-federation.org"
      },
      "url": canonicalUrl,
      "image": ogImage,
    })} />

    <link rel="shortcut icon" href="/jmd/09/favicon.ico">
    <link rel="icon" type="image/x-icon" href="/jmd/09/favicon.ico">
    <link href="https://fonts.googleapis.com/css?family=IM+Fell+Great+Primer" rel="stylesheet">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="/jmd/08/css/main.css">
    <link rel="stylesheet" href="/jmd/08/css/entry.css">
    <style>
      .container { background-image: url('/jmd/09/img/background.png'); }

#archive ul { display: flex; flex-wrap: wrap; gap: 0 1.5em; padding: 0; }
      #archive ul li { display: inline; padding: 0.2em 1em; text-align: left; }
      #archive ul li a { font-size: 1.1em; color: #ccc; white-space: nowrap; }
      #archive ul li a:hover { color: #fff; text-decoration: underline; }
    </style>
  </head>
  <body>
    <Nav client:only="react" />

    <div class="container">
      <header id="top">
        <div class="title-logo">
          <h1 class="logo">
            <img src="/jmd/09/img/title-logo.png" alt="Judgement Day 9（ジャッジメント・デイ9）">
          </h1>
          <p class="catchphrase">
            <span>審判<span class="hiragana">の</span>日<span class="hiragana">に </span>集結<span class="hiragana">せよ</span> <span class="inline-line"></span> 。</span>
          </p>
          <div class="event-info">
            <div class="event-date">
              <time datetime="2026-09-20">
                <span class="year">2026.</span><span class="month-date">9.20</span><span class="day">Sun</span>
              </time>
            </div>
            <p class="happy20th"><img src="/jmd/08/img/vs_logo.png" alt="Vampire Savior"><span></span></p>
          </div>
        </div>
        <div class="social">
          <ul>
            <li class="twitter">
              <a href="https://twitter.com/share" class="twitter-share-button"
                data-url="https://darkstalkers-federation.org/jmd/09/"
                data-text="Judgement Day 9" data-via="ds_federation"
                data-lang="ja" data-hashtags="JMD9">ツイート</a>
            </li>
          </ul>
        </div>
      </header>

      <div class="contents">

        <!-- 大会概要 -->
        <section id="summary" itemscope itemtype="https://schema.org/Event">
          <meta itemprop="name" content="Judgement Day 9（ジャッジメント・デイ9）">
          <h2 class="event-title">大会概要</h2>
          <p>ヴァンパイアセイヴァー大規模3on3大会<b>Judgement Day 9</b>の開催が決定！</p>
          <p>詳細については順次アップデートします。</p>
          <dl class="event-summary">
            <dt>イベント名称</dt><dd>Judgement Day 9</dd>
            <dt>開催日時</dt><dd>2026年9月20日（日）</dd>
            <dt>ゲームタイトル</dt><dd>ヴァンパイアセイヴァー</dd>
            <dt>大会形式</dt>
            <dd>予選 … 3チームor4チームによるリーグ戦or変則トーナメント（プレーオフあり）</dd>
            <dd>決勝 … 8チームによるシングルイリミネーショントーナメント</dd>
            <dt>入場料</dt>
            <dd>お一人様 3,000円（大会参加費込み）/ 観戦のみの場合 2,000円（調整中）</dd>
            <dt>会場</dt>
            <dd itemprop="location" itemscope itemtype="https://schema.org/Place">
              <a itemprop="url" href="https://espofield.com/" target="_blank" rel="noopener noreferrer">
                <span itemprop="name">eスポフィールド</span>
              </a>
            </dd>
            <dt>配信</dt>
            <dd><a href="https://www.twitch.tv/gamenewton" target="_blank" rel="noopener noreferrer">Twitch ニュートンチャンネル</a></dd>
          </dl>
        </section>

        <!-- 対戦表（大会終了後に更新） -->
        <!-- <section id="result">
          <h2>対戦表・トーナメント表</h2>
          <section class="archive">
            <h3>決勝トーナメント</h3>
            <ImageLightbox images={finalImages} client:only="react" />
          </section>
        </section> -->

        <!-- エントリーリスト（React・フル機能） -->
        <EntrySection
          client:only="react"
          dbPath="09/data"
          iconBase="/jmd/08/img/icons/"
          readOnly={false}
        />

        <!-- タイムテーブル（内容確定次第復活） -->
        <!-- <section id="timetable">
          <h2>タイムテーブル</h2>
          <p>詳細未定</p>
        </section> -->

        <section id="regulation">
          <h2>大会ルール</h2>
          <section>
            <h3>レギュレーション</h3>
            <div class="section-inner">
              <ul>
                <li>3on3チームマッチ</li>
                <li>スピード：ターボ3固定</li>
                <li>使用キャラの変更不可</li>
                <li>その他は工場出荷デフォルト設定</li>
                <li>特定技によるガード不能バグについては、広く認知されているので制限無し。ただしゲーム続行不能になるバグの利用は禁止（アナカリスの無敵状態は可）</li>
                <li>試合開始前にジャンケンを行い、勝利した側がコンパネ選択権（1Por2P）を得る</li>
                <li>試合開始前に先鋒の選手を審判に申告する。その後の変更は認めない</li>
                <li><b class="underline">勝ち抜き戦とし、中堅以降の順序は自由に決定できる</b></li>
                <li>コンパネの不具合が発生した場合はプレイを中断し、即座に運営へ申告すること</li>
                <li>ダブルKOは再試合</li>
              </ul>
            </div>
          </section>
          <section>
            <h3>大会進行の流れ</h3>
            <div class="section-inner">
              <p>未定</p>
            </div>
          </section>
          <section>
            <h3>注意事項</h3>
            <div class="section-inner">
              <ul>
                <li>当日はライブ配信およびメディア取材等で会場内の映像配信や写真撮影が行われます。あらかじめご了承ください。</li>
                <li>会場内は終日禁煙となります。</li>
                <li>会場内への飲食物の持ち込みは厳禁です。</li>
                <li><b class="underline">当日は会場全エリア貸切となりますので、通常利用時必要となる会員登録は必要ありません</b>。</li>
                <li>児童の入場料はかかりません。</li>
                <li>未成年者も入場、打ち上げの参加は可能ですが、飲酒は固くお断りいたします。</li>
                <li>他の参加者・店舗への迷惑行為を行うプレイヤーの参加は禁止です。</li>
                <li>運営側判断でエントリーを取り消しさせていただく場合があります。</li>
              </ul>
            </div>
          </section>
        </section>

        <!-- その他 -->
        <section id="others">
          <h2>その他</h2>
          <section id="archive">
            <h3>アーカイブ（過去大会）</h3>
            <ul>
              <li><a href="/judgementday/2013/">Judgement Day</a></li>
              <li><a href="/judgementday/02/">Judgement Day 2</a></li>
              <li><a href="/judgementday/03/">Judgement Day 3</a></li>
              <li><a href="/jmd/04/">Judgement Day 4</a></li>
              <li><a href="/jmd/05/">Judgement Day 5</a></li>
              <li><a href="/jmd/06/">Judgement Day 6</a></li>
              <li><a href="/jmd/07/">Judgement Day 7</a></li>
              <li><a href="/jmd/08/">Judgement Day 8</a></li>
            </ul>
          </section>
        </section>

        <!-- スタッフ -->
        <section id="staff" class="staff">
          <h2>公式アカウント・スタッフ一覧</h2>
          <ul class="staff-list">
            {[
              { img: 'savior3on3.jpg', name: 'Judgement Day',  role: '公式アカウント',       twitter: 'savior3on3' },
              { img: 'ririrililith.jpg',  name: 'リリィ',         role: '主催者',              twitter: 'ririrililith' },
              { img: 'Celibaka.jpg',      name: 'せり',           role: '運営その1',           twitter: 'Celibaka' },
              { img: 'dekamelon999.jpg',         name: 'デカメロン',     role: 'サイト構築・運営担当', twitter: 'dekamelon999' },
              { img: 'matsuda4951.jpg',          name: '松田さん',       role: 'イベントバックアップ', twitter: 'matsuda4951' },
              { img: 'xo_bison.jpg',             name: 'ニュートン若松さん', role: 'イベントバックアップ', twitter: 'xo_bison' },
            ].map(s => (
              <li>
                <div class="staff-logo-wrapper">
                  <img src={`/jmd/09/img/staff/${s.img}`} class="staff-logo" alt={s.name}>
                </div>
                <div class="staff-info">
                  <div class="staff-name">{s.name}</div>
                  <div class="staff-role">{s.role}</div>
                  <div class="staff-description">
                    <a href={`https://twitter.com/${s.twitter}`} class="twitter-follow-button"
                      data-show-count="false" data-lang="ja" target="_blank" rel="noopener noreferrer">@{s.twitter}さんをフォロー</a>
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </section>
      </div>

      <footer>
        <small>Illustration by アシオミマサト</small><br>
        <small>&copy; Darkstalkers Federation 2026</small>
      </footer>
    </div>

    <script>
      const bg = document.querySelector('.container') as HTMLElement;
      if (bg) {
        if (window.innerWidth > 600) {
          bg.addEventListener('scroll', () => {
            const diff = bg.scrollTop / 50;
            bg.style.backgroundPosition = `center calc(100px + ${Math.max(0, diff)}%)`;
          });
        } else {
          bg.style.backgroundPosition = 'center 100px';
          bg.style.backgroundSize = 'contain';
        }
      }
    </script>
    <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  </body>
</html>
